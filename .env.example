# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Optional: Azure price per 1M tokens, used for admin cost estimation only
AZURE_INPUT_COST_PER_1M=0
AZURE_OUTPUT_COST_PER_1M=0

# --- Email Delivery (Resend only) ---
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM_ADDRESS=noreply@app.example.com

# --- Email Settings ---
EMAIL_FROM_NAME=REscript
EMAIL_SUBJECT_PREFIX=[REscript Daily]
EMAIL_SUBJECT_PREFIX_ZH=[北美地产日报]
EMAIL_SUBJECT_PREFIX_EN=[REscript Daily]
SUPPORT_EMAIL=support@example.com
COMPANY_ADDRESS=123 Example St, New York, NY 10001

# --- Schedule ---
CRON_SCHEDULE=0 7 * * *
CRON_TIMEZONE=America/New_York

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID=price_your-stripe-price-id
STRIPE_ANNUAL_PRICE_ID=price_your-stripe-annual-price-id

# --- Security ---
ADMIN_TOKEN=change-me-to-a-strong-secret
VIEWER_TOKEN_SECRET=replace-with-a-different-long-random-secret

# --- App ---
BASE_URL=https://rescript.example.com

# --- Optional ---
DRY_RUN=false
LOG_LEVEL=info
